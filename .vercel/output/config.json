{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "(?<__isr_route>/__nuxt_content/(?:.*))",
      "dest": "/__fallback"
    },
    {
      "src": "/blog",
      "dest": "/blog"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/__nuxt_content/info/sql_dump.txt",
      "dest": "/__nuxt_content/info/sql_dump.txt"
    },
    {
      "src": "/__nuxt_content/info/query",
      "dest": "/__nuxt_content/info/query"
    },
    {
      "src": "/__nuxt_content/content/query",
      "dest": "/__nuxt_content/content/query"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/blog/?(?<slug>.+)",
      "dest": "/blog/[...slug]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}